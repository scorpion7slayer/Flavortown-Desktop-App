{
    "$schema": "https://schema.tauri.app/config/2",
    "app": {
        "security": {
            "csp": "default-src 'self' tauri: asset: blob: data:; connect-src https://flavortown.hackclub.com https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com data:; img-src 'self' asset: tauri: blob: data: https:; script-src 'self' 'unsafe-inline'"
        },
        "windows": [
            {
                "height": 600,
                "title": "flavortown-desktop-app",
                "width": 800
            }
        ]
    },
    "build": {
        "beforeBuildCommand": "bun run build",
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "bundle": {
        "active": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "signingIdentity": "-"
        },
        "targets": "all"
    },
    "identifier": "com.theo.flavortown-desktop-app",
    "productName": "flavortown-desktop-app",
    "version": "0.1.0"
}
